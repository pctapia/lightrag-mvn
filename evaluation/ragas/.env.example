# Java SDK query execution model
LIGHTRAG_JAVA_EVAL_CHAT_API_KEY=
LIGHTRAG_JAVA_EVAL_CHAT_BASE_URL=https://api.openai.com/v1/
LIGHTRAG_JAVA_EVAL_CHAT_MODEL=gpt-4o-mini

# Java SDK embedding model
LIGHTRAG_JAVA_EVAL_EMBEDDING_API_KEY=
LIGHTRAG_JAVA_EVAL_EMBEDDING_BASE_URL=https://api.openai.com/v1/
LIGHTRAG_JAVA_EVAL_EMBEDDING_MODEL=text-embedding-3-small
LIGHTRAG_JAVA_EVAL_STORAGE_PROFILE=in-memory

# RAGAS evaluator model
EVAL_LLM_BINDING_API_KEY=
EVAL_LLM_BINDING_HOST=https://api.openai.com/v1/
EVAL_LLM_MODEL=gpt-4o-mini

# RAGAS evaluator embedding model
EVAL_EMBEDDING_BINDING_API_KEY=
EVAL_EMBEDDING_BINDING_HOST=https://api.openai.com/v1/
EVAL_EMBEDDING_MODEL=text-embedding-3-large

# Optional tuning
EVAL_MAX_CONCURRENT=1
EVAL_QUERY_TOP_K=10
LIGHTRAG_JAVA_EVAL_CHUNK_TOP_K=10
LIGHTRAG_JAVA_EVAL_MAX_HOP=2
LIGHTRAG_JAVA_EVAL_PATH_TOP_K=3
LIGHTRAG_JAVA_EVAL_MULTI_HOP_ENABLED=true
LIGHTRAG_JAVA_EVAL_RETRIEVAL_ONLY=false
